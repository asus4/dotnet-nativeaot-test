<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>NativeFib</id>
    <version>1.0.0</version>
    <authors>dotnet-nativeaot-test</authors>
    <description>Sample NuGet native package: a Fibonacci function shipped as per-RID static libs (macOS/iOS/Android) and statically linked into Native AOT builds.</description>
    <tags>native nativeaot fibonacci sample interop</tags>
    <developmentDependency>true</developmentDependency>
  </metadata>
  <files>
    <!-- Consumer MSBuild logic (also under buildTransitive so it flows to transitive consumers). -->
    <file src="build/NativeFib.targets" target="build/NativeFib.targets" />
    <file src="build/NativeFib.targets" target="buildTransitive/NativeFib.targets" />

    <!-- Per-RID static libraries, produced by build/build_nativefib.sh. -->
    <file src="runtimes/**/*.a" target="runtimes" />
  </files>
</package>
