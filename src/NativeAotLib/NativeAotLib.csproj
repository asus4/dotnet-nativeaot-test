<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Library</OutputType>
    <AssemblyName>NativeAotLib</AssemblyName>

    <IsAotCompatible>true</IsAotCompatible>
    <PublishAot>true</PublishAot>
    <PublishAotUsingRuntimePack>true</PublishAotUsingRuntimePack>

    <!-- Required for the delegate* unmanaged function-pointer callback in HttpGet. -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup Condition="$(RuntimeIdentifier.StartsWith('android'))">
    <!-- Link with SONAME -->
    <LinkerArg Include="-Wl,-soname,libNativeAotLib.so" />
  </ItemGroup>
</Project>
